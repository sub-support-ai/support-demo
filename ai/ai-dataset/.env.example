# Qwen / любой OpenAI-совместимый провайдер. Раскомментируй нужный блок.

# --- Ollama локально ---
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# QWEN_MODEL=qwen2.5:72b

# --- DashScope (Alibaba Cloud, международный регион) ---
# OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# OPENAI_API_KEY=sk-...
# QWEN_MODEL=qwen-max
# (или qwen-plus / qwen-turbo / qwen2.5-72b-instruct)

# --- Together AI ---
# OPENAI_BASE_URL=https://api.together.xyz/v1
# OPENAI_API_KEY=...
# QWEN_MODEL=Qwen/Qwen2.5-72B-Instruct-Turbo

# --- vLLM self-hosted ---
# OPENAI_BASE_URL=http://your-vllm-host:8000/v1
# OPENAI_API_KEY=any-string
# QWEN_MODEL=Qwen/Qwen2.5-72B-Instruct
